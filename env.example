# ── LOSU .env.example ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Docker Compose reads this automatically from the host — never baked into image.
# For local Go runs, godotenv loads it automatically from the project root.

# ── Log Source ────────────────────────────────────────────────────────────────
# Host folder containing your log files (mounted into the Docker container).
LOG_PATH_HOST=./logs

# Path(s) inside the container — comma-separated for multi-file monitoring.
# Example single file:  LOSU_LOG_PATH=./logs/app.log
# Example multi-file:   LOSU_LOG_PATH=./logs/app.log,./logs/worker.log
LOSU_LOG_PATH=./logs/app.log

# ── Log Filtering ─────────────────────────────────────────────────────────────
# Minimum log level to display (DEBUG, INFO, WARN, ERROR)
LOSU_MIN_LEVEL=INFO

# ── EPS Thresholds (Errors Per Second) ────────────────────────────────────────
# Tune these to your app's normal baseline — no recompile needed.
LOSU_EPS_MINOR=0.1
LOSU_EPS_WARN=1.0
LOSU_EPS_CRITICAL=5.0

# ── WPS Thresholds (Warns Per Second) ─────────────────────────────────────────
LOSU_WPS_PRESSURE=50
LOSU_WPS_SUSPICIOUS=100
LOSU_WPS_PREINCIDENT=200

# ── Mobile Alerts (ntfy.sh) ───────────────────────────────────────────────────
# 1. Download the ntfy app (iOS/Android)
# 2. Subscribe to a unique topic name
# 3. Set LOSU_NTFY_TOPIC to match that topic name — instant push notifications for errors
LOSU_NTFY_TOPIC=losu-monitor-default

# Only send phone alerts when EPS is at or above this value.
# Default 1.0 prevents spam from occasional single errors.
# Set to 0 to always alert on any error.
LOSU_ALERT_EPS_THRESHOLD=1.0

# ── Heartbeat Report ──────────────────────────────────────────────────────────
# How often to send the periodic summary report (in minutes)
LOSU_REPORT_WINDOW=60

# ── AI Settings (Ollama) ──────────────────────────────────────────────────────
# Docker:  use http://ollama:11434 (resolves via Docker Compose network)
# Local:   use http://localhost:11434
LOSU_OLLAMA_HOST=http://ollama:11434
LOSU_AI_MODEL=llama3:latest

# ── Web Dashboard ─────────────────────────────────────────────────────────────
LOSU_WEB_ADDR=:8080
